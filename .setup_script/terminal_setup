#!/bin/sh

DEVSETTING_GIT=$(git rev-parse --show-toplevel)

DEVSETTING_DIR=$HOME/.devsetting
[ ! -d "$DEVSETTING_DIR" ] && mkdir -p "$DEVSETTING_DIR"

systemMessage=""

## Detect current environment ##################################################
currentShell=$(basename "$SHELL")
supportNVIM=0

case "$(uname -s)" in
    Linux*)  machine=Linux; supportNVIM=1 ;;
    Darwin*) machine=Mac;   supportNVIM=1 ;;
    CYGWIN*) machine=Cygwin ;;
    MINGW*)  machine=MinGw ;;
    *)       machine="UNKNOWN:$(uname -s)" ;;
esac

rm -f "$DEVSETTING_DIR/.env"
touch "$DEVSETTING_DIR/.env"

printf "# Do not modify this file !!\n"          >> "$DEVSETTING_DIR/.env"
printf "export DEVSETTING_TYPE=%s\n" "$machine"  >> "$DEVSETTING_DIR/.env"

if [ "$machine" = "Linux" ]; then
    if grep -qE "(Microsoft|WSL)" /proc/version >/dev/null 2>&1; then
        printf "export DEVSETTING_WSL=1\n" >> "$DEVSETTING_DIR/.env"
    else
        printf "export DEVSETTING_WSL=0\n" >> "$DEVSETTING_DIR/.env"
    fi
fi

## Create directory structure ##################################################
[ ! -d "$DEVSETTING_DIR/bin" ]    && mkdir -p "$DEVSETTING_DIR/bin"
[ ! -d "$DEVSETTING_DIR/git" ]    && mkdir -p "$DEVSETTING_DIR/git"
[ ! -L "$DEVSETTING_DIR/config" ] && ln -s "$DEVSETTING_GIT/config" "$DEVSETTING_DIR/config"
[ ! -L "$DEVSETTING_DIR/script" ] && ln -s "$DEVSETTING_GIT/script" "$DEVSETTING_DIR/script"
if [ "$supportNVIM" = "1" ]; then
    mkdir -p "$HOME/.config"
    if [ -L "$HOME/.config/nvim" ]; then
        unlink "$HOME/.config/nvim"
    elif [ -d "$HOME/.config/nvim" ]; then
        systemMessage="${systemMessage}nvim config backed up to $backupDir\n"
        mv "$HOME/.config/nvim" "$backupDir"
    fi
    ln -s "$DEVSETTING_DIR/config/nvim" "$HOME/.config/nvim"
fi

## Backup old configs and create symlinks ######################################
backupDir="$HOME/config_backup_$(date +%y%m%d%H%M%S)"
mkdir -p "$backupDir"

# Link a config file: backup the original if it exists, then create a symlink.
link_config() {
    target="$HOME/$1"
    src="$DEVSETTING_DIR/config/$1"
    if [ -f "$target" ] && [ ! -L "$target" ]; then
        systemMessage="${systemMessage}$1 backed up to $backupDir\n"
        mv "$target" "$backupDir"
    elif [ -L "$target" ]; then
        systemMessage="${systemMessage}Updating symlink: $1\n"
        unlink "$target"
    fi
    ln -s "$src" "$target"
}

link_config .vimrc
link_config .tigrc
link_config .tmux.conf

## Register devsetting in shell rc files #######################################
bashInit=".devsetting.bash"
bashRc="$HOME/.bashrc"
[ ! -f "$bashRc" ] && touch "$bashRc"
if ! grep -qw "$bashInit" "$bashRc"; then
    printf "[ -f %s/config/%s ] && . %s/config/%s\n" \
        "$DEVSETTING_DIR" "$bashInit" "$DEVSETTING_DIR" "$bashInit" >> "$bashRc"
fi

zshInit=".devsetting.zsh"
zshRc="$HOME/.zshrc"
if [ -f "$zshRc" ] && grep -qw "$zshInit" "$zshRc"; then
    : # already registered, do nothing
else
    if [ -f "$zshRc" ]; then
        systemMessage="${systemMessage}.zshrc backed up to $backupDir\n"
        mv "$zshRc" "$backupDir"
        touch "$zshRc"
        printf "# Your previous .zshrc was stored at %s\n" "$backupDir" >> "$zshRc"
    else
        touch "$zshRc"
    fi
    printf "# To use your own settings, comment out the line below\n" >> "$zshRc"
    printf "[ -f %s/config/%s ] && . %s/config/%s\n" \
        "$DEVSETTING_DIR" "$zshInit" "$DEVSETTING_DIR" "$zshInit" >> "$zshRc"
fi

## Post processing #############################################################
[ -z "$(ls -A "$backupDir")" ] && rmdir "$backupDir"

if [ -n "$systemMessage" ]; then
    printf "%b" "$systemMessage"
fi
printf "Done. Please re-launch your shell or run: source ~/.%src\n" "$currentShell"
